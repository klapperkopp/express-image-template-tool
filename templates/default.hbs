<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        /* The scaling magic */
        html {
            font-size: 1.111vw;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            width: 100vw;
            height: 100vh;
            margin: 0;
            overflow: hidden; 
        }

        .ride-container {
            position: relative; /* Crucial for absolutely positioning the logo */
            width: 100vw;
            height: 100vh;
            background-color: #333; 
            background-size: cover;
            background-position: center;
            border-radius: 0px; 
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            align-items: center;
            padding: 2rem; 
        }

        /* Top Right Logo Styling */
        .logo {
            position: absolute;
            bottom: 3rem; /* 30px from top */
            right: 3rem; /* 40px from right */
            height: 5rem; /* 40px height */
            width: auto;
            max-width: 20rem; /* 200px max width */
            object-fit: contain;
            /* Optional: Add drop shadow if logo is hard to see on light backgrounds */
            filter: drop-shadow(0px 2px 4px rgba(0,0,0,0.5));
        }

        .title-banner {
            background: rgba(15, 15, 15, 0.65);
            backdrop-filter: blur(4px);
            padding: 1.2rem 3rem; 
            border-radius: 3rem; 
            margin-top: 1rem; 
        }

        .title-banner h1 {
            color: #ffffff;
            font-size: 3.2rem; 
            font-weight: 700;
            text-align: center;
            letter-spacing: 0.05rem; 
        }

        .info-cards-wrapper {
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 6rem; 
            flex-grow: 1;
        }

        .card {
            background: rgba(25, 30, 35, 0.75);
            backdrop-filter: blur(8px);
            border-radius: 2rem; 
            width: 22rem; 
            padding: 3rem 1.5rem; 
            display: flex;
            flex-direction: column;
            align-items: center;
            color: #ffffff;
            text-align: center;
        }

        .driver-img {
            width: 11rem; 
            height: 11rem; 
            border-radius: 50%;
            object-fit: cover;
            margin-bottom: 1.5rem; 
        }

        .driver-name {
            font-size: 2.4rem; 
            font-weight: 700;
            margin-bottom: 0.8rem; 
        }

        .rating-wrapper {
            display: flex;
            align-items: center;
            gap: 0.6rem; 
        }

        .star-icon {
            color: #F8B124; 
            font-size: 2.4rem; 
        }

        .rating-score {
            font-size: 2.2rem; 
            font-weight: 700;
        }

        .car-img {
            width: 11rem; 
            height: 11rem; 
            border-radius: 50%;
            object-fit: cover;
            margin-bottom: 1.5rem; 
        }

        .plate-number {
            font-size: 2rem; 
            font-weight: 700;
            margin-bottom: 0.6rem; 
        }

        .car-type {
            font-size: 1.8rem; 
            font-weight: 600;
            line-height: 1.3;
        }

        .eta-banner {
            background: rgba(15, 15, 15, 0.75);
            backdrop-filter: blur(4px);
            padding: 1.2rem 4rem; 
            border-radius: 4rem; 
            margin-bottom: 1rem; 
        }

        .eta-banner h2 {
            color: #ffffff;
            font-size: 3.6rem; 
            font-weight: 700;
        }
    </style>
</head>
<body>

    <div class="ride-container" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('{{ backgroundImageUrl }}');">
        
        <img src="{{ logoUrl }}" alt="Logo" class="logo">
        
        <div class="title-banner">
            <h1>Your driver is on his way.</h1>
        </div>

        <div class="info-cards-wrapper">
            
            <div class="card">
                <img src="{{ driverImageUrl }}" alt="Driver" class="driver-img">
                <div class="driver-name">{{ driverName }}</div>
                <div class="rating-wrapper">
                    <span class="star-icon">★</span>
                    <span class="rating-score">{{ driverRating }}</span>
                </div>
            </div>

            <div class="card">
                <img src="{{ carImageUrl }}" alt="Car" class="car-img">
                <div class="plate-number">{{ carPlateNumber }}</div>
                <div class="car-type">{{ carType }}</div>
            </div>

        </div>

        <div class="eta-banner">
            <h2>ETA: {{ etaUntilArrival }}</h2>
        </div>

    </div>

</body>
</html>